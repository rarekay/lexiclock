# Never cache the service worker or HTML
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache

# Cache everything else for 1 year (content-addressed assets)
/words/*
  Cache-Control: public, max-age=31536000

/icons/*
  Cache-Control: public, max-age=31536000

/*.js
  Cache-Control: public, max-age=86400

/*.css
  Cache-Control: public, max-age=86400
